# =============================================================================
# .env.prod.example — Production environment variables template
# =============================================================================
# Copy this to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod
#
# NEVER commit .env.prod to git!
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5.4

# ── Langfuse (LLM observability) ────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret
MINIO_BUCKET=observator
MINIO_SECURE=false

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_COLLECTION=evidence

# ── Tavily (optional — web search for agent) ────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here

# ── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
MIN_COHORT_SIZE=10
MAX_QUERY_LIMIT=1000
