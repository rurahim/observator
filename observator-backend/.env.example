# Database
DATABASE_URL=postgresql+asyncpg://observator:observator@localhost:5432/observator
DATABASE_URL_SYNC=postgresql://observator:observator@localhost:5432/observator

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=observator
MINIO_SECURE=false

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=evidence

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
MIN_COHORT_SIZE=10
MAX_QUERY_LIMIT=1000
